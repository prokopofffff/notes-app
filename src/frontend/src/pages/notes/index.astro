---
import Base from '../../layouts/Base.astro';
---
<Base title="My Notes">
  <header class="header">
    <span class="header-title">My Notes</span>
    <div style="display:flex;gap:var(--space-3);align-items:center">
      <button class="btn btn-primary" id="new-note-btn">+ New Note</button>
      <button class="btn btn-ghost" id="logout-btn">Sign out</button>
    </div>
  </header>

  <main class="container" style="padding-top: var(--space-6); padding-bottom: var(--space-6)">
    <div id="loading-state" style="text-align:center; padding: var(--space-12); color: var(--color-text-secondary); font-size: var(--text-sm)">
      Loading notes…
    </div>
    <div id="empty-state" style="display:none; text-align:center; padding: var(--space-12)">
      <p style="color: var(--color-text-secondary); font-size: var(--text-md); margin-bottom: var(--space-4)">No notes yet</p>
      <button class="btn btn-primary" id="empty-new-btn">Create your first note</button>
    </div>
    <div id="error-state" style="display:none; text-align:center; padding: var(--space-12); color: var(--color-danger); font-size: var(--text-sm)"></div>
    <div id="notes-grid" class="notes-grid" style="display:none"></div>
  </main>

  <!-- Delete confirmation modal -->
  <div id="delete-modal" class="modal-overlay" style="display:none">
    <div class="modal">
      <h2 style="font-size: var(--text-lg); font-weight: 600; margin-bottom: var(--space-3)">Delete note?</h2>
      <p style="color: var(--color-text-secondary); font-size: var(--text-sm); margin-bottom: var(--space-6)">This action cannot be undone.</p>
      <div style="display:flex; gap: var(--space-3); justify-content: flex-end">
        <button class="btn btn-ghost" id="cancel-delete-btn">Cancel</button>
        <button class="btn btn-danger" id="confirm-delete-btn">Delete</button>
      </div>
    </div>
  </div>
</Base>

<style>
  .notes-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .notes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .note-title {
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .note-preview {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }

  .note-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .note-date {
    font-size: var(--text-xs);
    color: var(--color-text-placeholder);
  }

  .delete-btn {
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    opacity: 0;
    transition: opacity 0.15s;
  }

  .note-card:hover .delete-btn {
    opacity: 1;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    z-index: 100;
  }

  .modal {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    width: 100%;
    max-width: 360px;
    box-shadow: var(--shadow-md);
  }
</style>

<script>
  import { api } from '../../lib/api';
  import type { Note } from '../../../../shared/types/notes';

  // Auth guard
  const token = typeof localStorage !== 'undefined' ? localStorage.getItem('token') : null;
  if (!token) {
    window.location.href = '/';
  }

  const loadingState = document.getElementById('loading-state')!;
  const emptyState = document.getElementById('empty-state')!;
  const errorState = document.getElementById('error-state')!;
  const notesGrid = document.getElementById('notes-grid')!;
  const deleteModal = document.getElementById('delete-modal')!;
  const confirmDeleteBtn = document.getElementById('confirm-delete-btn')!;
  const cancelDeleteBtn = document.getElementById('cancel-delete-btn')!;

  let notes: Note[] = [];
  let pendingDeleteId: number | null = null;

  function formatDate(iso: string): string {
    const d = new Date(iso);
    return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function renderNotes(): void {
    if (notes.length === 0) {
      notesGrid.style.display = 'none';
      emptyState.style.display = 'block';
      return;
    }
    emptyState.style.display = 'none';
    notesGrid.style.display = 'grid';
    notesGrid.innerHTML = notes.map((note) => `
      <div class="note-card" data-id="${note.id}">
        <div class="note-title">${escapeHtml(note.title || 'Untitled')}</div>
        <div class="note-preview">${escapeHtml(note.content)}</div>
        <div class="note-meta">
          <span class="note-date">${formatDate(note.updated_at)}</span>
          <button class="btn btn-danger delete-btn" data-delete="${note.id}">Delete</button>
        </div>
      </div>
    `).join('');

    notesGrid.querySelectorAll<HTMLElement>('.note-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('[data-delete]')) return;
        const id = card.dataset['id'];
        if (id) window.location.href = `/notes/edit?id=${id}`;
      });
    });

    notesGrid.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset['delete'];
        if (id) openDeleteModal(parseInt(id, 10));
      });
    });
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function loadNotes(): Promise<void> {
    try {
      notes = await api.getNotes();
      loadingState.style.display = 'none';
      renderNotes();
    } catch (err) {
      loadingState.style.display = 'none';
      errorState.style.display = 'block';
      errorState.textContent = err instanceof Error ? err.message : 'Failed to load notes';
    }
  }

  function openDeleteModal(id: number): void {
    pendingDeleteId = id;
    deleteModal.style.display = 'flex';
  }

  function closeDeleteModal(): void {
    pendingDeleteId = null;
    deleteModal.style.display = 'none';
  }

  cancelDeleteBtn.addEventListener('click', closeDeleteModal);
  deleteModal.addEventListener('click', (e) => {
    if (e.target === deleteModal) closeDeleteModal();
  });

  confirmDeleteBtn.addEventListener('click', async () => {
    if (pendingDeleteId === null) return;
    const id = pendingDeleteId;
    closeDeleteModal();
    try {
      await api.deleteNote(id);
      notes = notes.filter((n) => n.id !== id);
      renderNotes();
    } catch (err) {
      alert(err instanceof Error ? err.message : 'Failed to delete note');
    }
  });

  document.getElementById('new-note-btn')!.addEventListener('click', () => {
    window.location.href = '/notes/new';
  });

  document.getElementById('empty-new-btn')!.addEventListener('click', () => {
    window.location.href = '/notes/new';
  });

  document.getElementById('logout-btn')!.addEventListener('click', () => {
    localStorage.removeItem('token');
    window.location.href = '/';
  });

  loadNotes();
</script>
